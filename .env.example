# Copy this file to .env and replace values before running the ASI:One agent.
# Never commit your real seed phrase or API keys.

AGENT_NAME=vendorverdict
AGENT_SEED=replace-this-with-a-long-random-seed-phrase
AGENT_PORT=8001

# Set to 0 for fallback-only demo mode if live vendor pages are blocked or slow.
VENDORVERDICT_LIVE_EVIDENCE=1

# Set to 0 to disable deterministic discovery of likely official source URLs for unknown vendors.
VENDORVERDICT_SOURCE_DISCOVERY=1

# Optional for later live evidence collection / LLM summarization.
ASI_ONE_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Payment Protocol / monetization demo
# Keeps the free review available, while premium reports can request payment.
VENDORVERDICT_PAYMENT_ENABLED=1
VENDORVERDICT_PREMIUM_PRICE_FET=0.05
FET_USE_TESTNET=true

# Demo mode accepts committed Payment Protocol messages without on-chain verification.
# Set to 0 for real FET transaction verification through cosmpy.
VENDORVERDICT_PAYMENT_DEMO_MODE=1

# Optional override if the runtime cannot read the agent wallet address.
VENDORVERDICT_PAYMENT_RECIPIENT=

# Production report API
# These settings power the FastAPI report-management backend.
VENDORVERDICT_API_DB_PATH=data/vendorverdict.sqlite3
VENDORVERDICT_API_EXPORT_DIR=reports
VENDORVERDICT_API_LIVE_EVIDENCE=1
VENDORVERDICT_API_HOST=0.0.0.0
VENDORVERDICT_API_PORT=8080

# Optional comma-separated origins for future browser dashboards.
VENDORVERDICT_API_CORS_ORIGINS=

# Dashboard/API authentication
# Enable before exposing the dashboard or API outside localhost.
VENDORVERDICT_AUTH_ENABLED=0
VENDORVERDICT_AUTH_USERNAME=admin
VENDORVERDICT_AUTH_PASSWORD=replace-with-a-strong-password
VENDORVERDICT_AUTH_SECRET=replace-with-a-long-random-session-secret
VENDORVERDICT_AUTH_SECURE_COOKIE=0
VENDORVERDICT_AUTH_SESSION_SECONDS=43200

# Optional local VM backup settings used by scripts/backup_vendorverdict.sh.
VENDORVERDICT_BACKUP_DIR=/var/backups/vendorverdict
VENDORVERDICT_BACKUP_RETENTION_DAYS=14

# Production monitoring settings. PUBLIC_URL is optional but recommended after HTTPS is live.
VENDORVERDICT_PUBLIC_URL=https://vendorverdict.docoply.com
VENDORVERDICT_MONITOR_MAX_BACKUP_AGE_HOURS=36
VENDORVERDICT_MONITOR_MAX_DISK_USED_PERCENT=85
VENDORVERDICT_MONITOR_CURL_TIMEOUT_SECONDS=10
