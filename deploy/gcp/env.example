# Copy to /etc/vendorverdict/vendorverdict.env on the VM.
# Do not commit real production secrets.

VENDORVERDICT_LIVE_EVIDENCE=1
VENDORVERDICT_SOURCE_DISCOVERY=1

VENDORVERDICT_PAYMENT_ENABLED=1
VENDORVERDICT_PAYMENT_DEMO_MODE=1
VENDORVERDICT_PREMIUM_PRICE_FET=0.05
VENDORVERDICT_PAYMENT_RECIPIENT=

VENDORVERDICT_API_HOST=127.0.0.1
VENDORVERDICT_API_PORT=8080
VENDORVERDICT_API_DB_PATH=/var/lib/vendorverdict/vendorverdict.sqlite3
VENDORVERDICT_API_EXPORT_DIR=/var/lib/vendorverdict/reports
VENDORVERDICT_API_LIVE_EVIDENCE=1
VENDORVERDICT_API_CORS_ORIGINS=

VENDORVERDICT_AUTH_ENABLED=1
VENDORVERDICT_AUTH_USERNAME=admin
VENDORVERDICT_AUTH_PASSWORD=replace-with-a-strong-password
VENDORVERDICT_AUTH_SECRET=replace-with-a-long-random-session-secret
VENDORVERDICT_AUTH_SECURE_COOKIE=1
VENDORVERDICT_AUTH_SESSION_SECONDS=43200

# Local VM backup settings. The systemd timer runs nightly at 02:15 UTC.
VENDORVERDICT_BACKUP_DIR=/var/backups/vendorverdict
VENDORVERDICT_BACKUP_RETENTION_DAYS=14

# Production monitoring settings. PUBLIC_URL is optional but recommended after HTTPS is live.
VENDORVERDICT_PUBLIC_URL=https://vendorverdict.docoply.com
VENDORVERDICT_MONITOR_MAX_BACKUP_AGE_HOURS=36
VENDORVERDICT_MONITOR_MAX_DISK_USED_PERCENT=85
VENDORVERDICT_MONITOR_CURL_TIMEOUT_SECONDS=10

# Optional monitor alerts. Use a webhook first; email requires local mail/sendmail setup.
VENDORVERDICT_ALERT_ENABLED=0
VENDORVERDICT_ALERT_NAME="VendorVerdict production"
VENDORVERDICT_ALERT_WEBHOOK_URL=
VENDORVERDICT_ALERT_WEBHOOK_FORMAT=generic
VENDORVERDICT_ALERT_EMAIL_TO=
VENDORVERDICT_ALERT_EMAIL_FROM=vendorverdict@docoply.com
VENDORVERDICT_ALERT_COOLDOWN_SECONDS=3600
VENDORVERDICT_ALERT_STATE_DIR=/var/lib/vendorverdict/monitor

# Optional lead notifications for public demo/pilot form submissions.
# If LEAD_WEBHOOK_URL is empty, the app falls back to VENDORVERDICT_ALERT_WEBHOOK_URL.
VENDORVERDICT_LEAD_NOTIFY_ENABLED=0
VENDORVERDICT_LEAD_NOTIFY_NAME="VendorVerdict lead capture"
VENDORVERDICT_LEAD_WEBHOOK_URL=
VENDORVERDICT_LEAD_WEBHOOK_FORMAT=generic
VENDORVERDICT_LEAD_EMAIL_TO=
VENDORVERDICT_LEAD_EMAIL_FROM=vendorverdict@docoply.com
VENDORVERDICT_LEAD_NOTIFY_TIMEOUT_SECONDS=10

# Non-secret dashboard-editable defaults. These can also be edited at /dashboard/settings.
VENDORVERDICT_COMPANY_NAME="VendorVerdict"
VENDORVERDICT_DEFAULT_REVIEW_REGION="UK"
VENDORVERDICT_DEFAULT_DATA_SENSITIVITY="medium"
VENDORVERDICT_DEFAULT_PROPOSAL_PRICE="From £1,000/month after pilot"
VENDORVERDICT_DEFAULT_PROPOSAL_BILLING="Monthly or quarterly subscription after the paid pilot, depending on review volume and support needs."
VENDORVERDICT_DEFAULT_FOLLOW_UP_DAYS="7"
VENDORVERDICT_DEFAULT_PAYMENT_DUE_DAYS="14"
VENDORVERDICT_DEFAULT_PAYMENT_URL=""
VENDORVERDICT_OPERATOR_EMAIL=""

# Optional direct proposal email sending from the dashboard.
# Store real SMTP credentials only in /etc/vendorverdict/vendorverdict.env.
VENDORVERDICT_EMAIL_SEND_ENABLED=0
VENDORVERDICT_SMTP_HOST=
VENDORVERDICT_SMTP_PORT=587
VENDORVERDICT_SMTP_USERNAME=
VENDORVERDICT_SMTP_PASSWORD=
VENDORVERDICT_SMTP_FROM=vendorverdict@docoply.com
VENDORVERDICT_SMTP_FROM_NAME="VendorVerdict"
VENDORVERDICT_SMTP_STARTTLS=1
VENDORVERDICT_SMTP_TIMEOUT_SECONDS=15

# Optional Stripe Checkout link creation from proposal payment screens.
# Store real Stripe secret keys only in /etc/vendorverdict/vendorverdict.env on production.
VENDORVERDICT_STRIPE_CHECKOUT_ENABLED=0
VENDORVERDICT_STRIPE_SECRET_KEY=
VENDORVERDICT_STRIPE_CURRENCY=gbp
VENDORVERDICT_STRIPE_SUCCESS_URL=
VENDORVERDICT_STRIPE_CANCEL_URL=
VENDORVERDICT_STRIPE_TIMEOUT_SECONDS=15
