# Copy to /etc/vendorverdict/vendorverdict.env on the VM.
# Do not commit real production secrets.

VENDORVERDICT_LIVE_EVIDENCE=1
VENDORVERDICT_SOURCE_DISCOVERY=1

VENDORVERDICT_PAYMENT_ENABLED=1
VENDORVERDICT_PAYMENT_DEMO_MODE=1
VENDORVERDICT_PREMIUM_PRICE_FET=0.05
VENDORVERDICT_PAYMENT_RECIPIENT=

VENDORVERDICT_API_HOST=127.0.0.1
VENDORVERDICT_API_PORT=8080
VENDORVERDICT_API_DB_PATH=/var/lib/vendorverdict/vendorverdict.sqlite3
VENDORVERDICT_API_EXPORT_DIR=/var/lib/vendorverdict/reports
VENDORVERDICT_API_LIVE_EVIDENCE=1
VENDORVERDICT_API_CORS_ORIGINS=

VENDORVERDICT_AUTH_ENABLED=1
VENDORVERDICT_AUTH_USERNAME=admin
VENDORVERDICT_AUTH_PASSWORD=replace-with-a-strong-password
VENDORVERDICT_AUTH_SECRET=replace-with-a-long-random-session-secret
VENDORVERDICT_AUTH_SECURE_COOKIE=1
VENDORVERDICT_AUTH_SESSION_SECONDS=43200
